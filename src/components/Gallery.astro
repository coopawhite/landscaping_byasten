---
const baseUrl = import.meta.env.BASE_URL;

const images = [
  { src: `${baseUrl}images/gallery-1.jpg`, alt: 'Garden design and landscaping project' },
  { src: `${baseUrl}images/gallery-2.jpg`, alt: 'Lawn care and maintenance' },
  { src: `${baseUrl}images/gallery-3.jpg`, alt: 'Paving and pathway installation' },
  { src: `${baseUrl}images/gallery-4.jpg`, alt: 'Retaining wall construction' },
  { src: `${baseUrl}images/gallery-5.jpg`, alt: 'Native garden planting' },
  { src: `${baseUrl}images/gallery-6.jpg`, alt: 'Backyard transformation' },
];
---

<section id="gallery" class="bg-stone-900 py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-3">
      Our Work
    </h2>
    <p class="text-stone-400 text-center mb-12 text-sm tracking-widest uppercase">
      Projects across the Shire &amp; Illawarra
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {images.map((image) => (
        <div class="overflow-hidden rounded-sm aspect-square">
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          />
        </div>
      ))}
    </div>
  </div>
</section>
