---
const images = [
  { src: '/images/gallery-2.jpg', alt: 'Garden design and landscaping project',  caption: 'Garden Design' },
  { src: '/images/gallery-5.jpg', alt: 'Lawn care and maintenance',               caption: 'Lawn Care' },
  { src: '/images/gallery-1.jpg', alt: 'Paving and pathway installation',          caption: 'Pathways' },
  { src: '/images/gallery-4.jpg', alt: 'Retaining wall construction',              caption: 'Retaining Walls' },
  { src: '/images/gallery-3.jpg', alt: 'Native garden planting',                   caption: 'Native Planting' },
  { src: '/images/gallery-6.jpg', alt: 'Backyard transformation',                  caption: 'Transformation' },
];

// First image is full-width on mobile (col-span-2). The remaining (images.length - 1)
// fill a 2-col grid. If that count is odd, the last image is alone in its row.
const lastIsAlone = (images.length - 1) % 2 === 1;
---

<section id="gallery" class="bg-sand py-24 md:py-32 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.35em] uppercase text-sage font-medium mb-4">Our Work</p>
      <h2 class="font-display font-semibold text-ink leading-tight" style="font-size: clamp(2.25rem, 5vw, 3.5rem);">
        Projects across the region
      </h2>
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {images.map((image, i) => (
        <div class={`gallery-item group relative overflow-hidden ${i === 0 ? 'col-span-2 lg:col-span-1' : ''} ${lastIsAlone && i === images.length - 1 ? 'col-span-2 lg:col-span-1' : ''}`}>
          <div class="aspect-square overflow-hidden">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          {/* Caption overlay removed */}
        </div>
      ))}
    </div>

  </div>
</section>
