---
const services = [
  { icon: '🌿', name: 'Lawn Care',      description: 'Mowing, edging, fertilising and seasonal treatments.' },
  { icon: '🌱', name: 'Garden Design',  description: 'Custom planting plans and garden makeovers.' },
  { icon: '🪨', name: 'Paving',         description: 'Driveways, pathways, patios and retaining walls.' },
  { icon: '✂️', name: 'Maintenance',    description: 'Ongoing care to keep your property looking its best.' },
];
---

<section id="services" class="bg-stone-100 py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-stone-800 text-center mb-3">
      What We Do
    </h2>
    <p class="text-stone-500 text-center mb-12 text-sm tracking-widest uppercase">
      Serving the Shire &amp; Illawarra
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <div class="bg-white rounded-sm border-t-4 border-green-600 p-6 shadow-sm">
          <div class="text-4xl mb-4">{service.icon}</div>
          <h3 class="font-serif text-lg font-bold text-stone-800 mb-2">{service.name}</h3>
          <p class="text-stone-500 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
