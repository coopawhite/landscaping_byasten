---
const baseUrl = import.meta.env.BASE_URL;
---

<section id="home" class="grain relative h-[55vh] md:h-[60vh] overflow-hidden flex items-center">
  <!-- Full-bleed background photo -->
  <img
    src={`${baseUrl}/images/hero.jpg`}
    alt="Landscaping work by Landscapes By Asten in the Shire and Illawarra"
    class="absolute inset-0 w-full h-full object-cover z-0"
  />

  <!-- Gradient overlay: cream fade from bottom-left, subtle across whole image -->
  <div
    class="absolute inset-0 z-10"
    style="background: linear-gradient(105deg, rgba(247,244,239,0.92) 0%, rgba(247,244,239,0.75) 45%, rgba(247,244,239,0.15) 100%);"
  ></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-8 md:px-16 py-12">
    <div class="max-w-xl">
      <p class="fade-up text-xs tracking-[0.35em] text-sage uppercase mb-4 font-sans font-medium">
        Shire &amp; Illawarra
      </p>
      <h1 class="fade-up fade-up-delay-1 font-display font-semibold leading-[0.9] text-ink mb-4" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Landscapes<br />By Asten
      </h1>
      <p class="fade-up fade-up-delay-2 font-sans font-light text-ink-muted text-base md:text-lg mb-7 leading-relaxed">
        Your local landscaping experts — crafting outdoor spaces that endure.
      </p>
      <a
        href="#contact"
        class="fade-up fade-up-delay-3 inline-flex items-center gap-3 bg-sage-deep hover:bg-sage text-cream text-xs uppercase tracking-widest px-6 py-3 transition-colors duration-300"
      >
        Get in Touch
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>
</section>
