---
const baseUrl = import.meta.env.BASE_URL;
---

<section id="home" class="relative min-h-screen overflow-hidden flex">
  <!-- Full-bleed background photo (right side visible through clip) -->
  <img
    src={`${baseUrl}/images/hero.jpg`}
    alt="Landscaping work by Landscapes By Asten in the Shire and Illawarra"
    class="absolute inset-0 w-full h-full object-cover z-0"
  />

  <!-- Dark green left panel with diagonal clip-path -->
  <div
    class="relative z-10 flex flex-col justify-end bg-[#1a2e1a] w-full md:w-[58%] px-8 md:px-16 py-20 md:py-28 min-h-screen"
    style="clip-path: polygon(0 0, 100% 0, 82% 100%, 0 100%);"
  >
    <p class="text-xs tracking-[0.3em] text-green-400 uppercase mb-4">
      Shire &amp; Illawarra
    </p>
    <h1 class="font-serif text-5xl md:text-7xl font-extrabold text-white leading-none mb-5">
      Landscapes<br />By Asten
    </h1>
    <p class="text-neutral-300 text-lg md:text-xl mb-10">
      Your local landscaping experts
    </p>
    <a
      href="#contact"
      class="inline-block bg-green-600 hover:bg-green-500 text-white font-semibold text-sm px-8 py-4 rounded-sm transition-colors w-fit"
    >
      Get in Touch ↓
    </a>
  </div>
</section>
