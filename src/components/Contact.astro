---
const formspreeEndpoint = 'https://formspree.io/f/maqlpvlo';
---

<section id="contact" class="bg-cream py-24 md:py-32 px-6">
  <div class="max-w-5xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-start">

      <!-- Left: copy -->
      <div class="md:pt-2">
        <p class="text-xs tracking-[0.35em] uppercase text-sage font-medium mb-4">Contact Us</p>
        <h2 class="font-display font-semibold text-ink leading-tight mb-6" style="font-size: clamp(2.25rem, 5vw, 3.5rem);">
          Let's create something beautiful
        </h2>
        <p class="text-ink-muted font-light leading-relaxed mb-8">
          We service the Shire &amp; Illawarra regions. Fill in the form and we'll be in touch shortly to discuss your project.
        </p>

        <!-- Contact details -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class="text-sage flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </span>
            <span class="text-sm text-ink-muted font-light">Shire &amp; Illawarra, NSW</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sage flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            <span class="text-sm text-ink-muted font-light">info@landscapesbyasten.com.au</span>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <form action={formspreeEndpoint} method="POST" class="flex flex-col gap-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-xs uppercase tracking-widest text-ink-muted font-medium mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full border border-border bg-white px-4 py-3 text-ink text-sm focus:outline-none focus:ring-2 focus:ring-sage placeholder:text-ink-muted/50"
            />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-ink-muted font-medium mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full border border-border bg-white px-4 py-3 text-ink text-sm focus:outline-none focus:ring-2 focus:ring-sage placeholder:text-ink-muted/50"
            />
          </div>
        </div>

        <div>
          <label for="phone" class="block text-xs uppercase tracking-widest text-ink-muted font-medium mb-2">Phone <span class="normal-case tracking-normal opacity-50">(optional)</span></label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="04XX XXX XXX"
            class="w-full border border-border bg-white px-4 py-3 text-ink text-sm focus:outline-none focus:ring-2 focus:ring-sage placeholder:text-ink-muted/50"
          />
        </div>

        <div>
          <label for="message" class="block text-xs uppercase tracking-widest text-ink-muted font-medium mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Tell us about your project..."
            class="w-full border border-border bg-white px-4 py-3 text-ink text-sm focus:outline-none focus:ring-2 focus:ring-sage resize-none placeholder:text-ink-muted/50"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-sage-deep hover:bg-sage text-cream text-xs uppercase tracking-widest py-4 transition-colors duration-300 font-medium"
        >
          Send Message
        </button>

      </form>
    </div>
  </div>
</section>
