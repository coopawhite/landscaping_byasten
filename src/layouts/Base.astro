---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Landscapes By Asten',
  description = 'Professional landscaping and garden design services in the Shire & Illawarra regions of NSW.',
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G86ZCBMWT9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G86ZCBMWT9');
    </script>
  </head>
  <body class="bg-cream font-sans antialiased">

    <!-- Sticky nav -->
    <nav class="sticky top-0 z-50 bg-cream border-b border-border">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

        <!-- Brand -->
        <a href="#home" class="font-display text-xl font-semibold text-ink leading-none tracking-tight">
          Landscapes <span class="text-sage-deep">By Asten</span>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-8">
          <a href="#services" class="text-xs uppercase tracking-widest text-ink-muted hover:text-sage-deep transition-colors duration-200">Services</a>
          <a href="#gallery"  class="text-xs uppercase tracking-widest text-ink-muted hover:text-sage-deep transition-colors duration-200">Gallery</a>
          <a href="#contact"  class="text-xs uppercase tracking-widest text-ink-muted hover:text-sage-deep transition-colors duration-200">Contact</a>
          <a
            href="#contact"
            class="text-xs uppercase tracking-widest bg-sage-deep text-cream px-5 py-2.5 hover:bg-sage transition-colors duration-200"
          >
            Get a Quote
          </a>
        </div>

        <!-- Mobile hamburger (CSS-only toggle) -->
        <label for="menu-toggle" aria-label="Open navigation menu" class="md:hidden cursor-pointer text-ink-muted hover:text-sage-deep p-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <span class="sr-only">Open navigation menu</span>
        </label>
      </div>

      <!-- Mobile menu overlay -->
      <input type="checkbox" id="menu-toggle" class="hidden peer" />
      <div class="hidden peer-checked:flex md:hidden fixed inset-0 z-40 flex-col bg-cream border-t border-border">
        <!-- Close button -->
        <label for="menu-toggle" class="absolute top-5 right-6 cursor-pointer text-ink-muted hover:text-sage-deep">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </label>
        <div class="flex flex-col gap-8 justify-center items-center flex-1">
          <a href="#services" onclick="document.getElementById('menu-toggle').checked=false" class="font-display text-4xl text-ink hover:text-sage-deep transition-colors">Services</a>
          <a href="#gallery"  onclick="document.getElementById('menu-toggle').checked=false" class="font-display text-4xl text-ink hover:text-sage-deep transition-colors">Gallery</a>
          <a href="#contact"  onclick="document.getElementById('menu-toggle').checked=false" class="font-display text-4xl text-ink hover:text-sage-deep transition-colors">Contact</a>
          <a
            href="#contact"
            onclick="document.getElementById('menu-toggle').checked=false"
            class="mt-4 text-sm uppercase tracking-widest bg-sage-deep text-cream px-8 py-3 hover:bg-sage transition-colors"
          >
            Get a Quote
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="bg-ink py-10 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <span class="font-display text-lg text-cream/80 font-medium">Landscapes By Asten</span>

        <!-- Social links -->
        <div class="flex items-center gap-5">
          <a href="https://www.instagram.com/landscapesbyasten/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-cream/40 hover:text-cream/80 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.974.974 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.974.974-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.974-.974-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608.974-.974 2.242-1.246 3.608-1.308C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.332.014 7.052.072 5.197.157 3.355.673 1.965 2.063.573 3.453.057 5.296-.028 7.15-.086 8.43-.1 8.84-.1 12c0 3.16.014 3.57.072 4.85.085 1.853.601 3.696 1.991 5.086 1.39 1.39 3.233 1.906 5.087 1.991C8.43 23.986 8.84 24 12 24s3.57-.014 4.85-.072c1.853-.085 3.696-.601 5.086-1.991 1.39-1.39 1.906-3.233 1.991-5.087.058-1.28.072-1.69.072-4.85 0-3.16-.014-3.57-.072-4.85-.085-1.853-.601-3.696-1.991-5.086C20.546.673 18.703.157 16.85.072 15.57.014 15.16 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/61574080706055" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-cream/40 hover:text-cream/80 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.885v2.27h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
        </div>

        <span class="text-xs uppercase tracking-widest text-cream/40">© 2026 · Shire &amp; Illawarra</span>
      </div>
    </footer>

  </body>
</html>
